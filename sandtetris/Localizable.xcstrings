    "settings_sensitivity_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust horizontal movement responsiveness. Higher values make blocks move faster in response to finger movement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "横移動の反応速度を調整できます。値が大きいほど、指の動きに対してブロックが速く移動します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整水平移动响应速度。数值越大，方块对手指移动的响应越快"
          }
        }
      }
    },
    "settings_width_label": {
      "localizations": {
