    "settings_color_count_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust the number of colors that appear as blocks. More colors increase difficulty. Changing this value will reset the game"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブロックとして出現する色の数を調整できます。色が多いほど難易度が上がります。値を変更するとゲームがリセットされます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整方块出现的颜色数量。颜色越多难度越大。更改此值将重置游戏"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "블록으로 등장하는 색상 수를 조절합니다. 색상이 많을수록 난이도가 높아집니다. 값을 변경하면 게임이 초기화됩니다"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "調整方塊出現的顏色數量。顏色越多難度越大。更改此值將重置遊戲"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez le nombre de couleurs qui apparaissent comme blocs. Plus de couleurs augmentent la difficulté. Changer cette valeur réinitialisera le jeu"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe die Anzahl der Farben an, die als Blöcke erscheinen. Mehr Farben erhoehen den Schwierigkeitsgrad. Durch Aendern dieses Werts wird das Spiel zurueckgesetzt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta el número de colores que aparecen como bloques. Más colores aumentan la dificultad. Cambiar este valor reiniciará el juego"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste o número de cores que aparecem como blocos. Mais cores aumentam a dificuldade. Alterar este valor reiniciará o jogo"
          }
        }
      }
    },
