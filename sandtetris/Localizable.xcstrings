{
  "sourceLanguage": "en",
  "strings": {
    "?": {
      "comment": "A placeholder text used when the next piece is not yet set.",
      "isCommentAutoGenerated": true
    },
    "(%lld)": {
      "comment": "A badge indicating the number of rewards that can be claimed. The argument is the count of rewards that can be claimed.",
      "isCommentAutoGenerated": true
    },
    "%@を%lldコインで購入します。\n現在のコイン: %lld": {
      "comment": "A message displaying the name of a skin, the cost of the skin as a number of coins, and the current number of coins the user has. The first argument is the localized name of the skin. The second argument is the cost of the skin as a number of coins. The third argument is the current number of coins the user has.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$@を%2$lldコインで購入します。\n現在のコイン: %3$lld"
          }
        }
      }
    },
    "%lld": {
      "comment": "A label displaying the number of coins the player has. The argument is the number of coins the player has.",
      "isCommentAutoGenerated": true
    },
    "%lld/%lld": {
      "comment": "A label displaying the number of unlocked achievements out of the total number of achievements. The first argument is the count of unlocked achievements. The second argument is the total count of achievements.",
      "isCommentAutoGenerated": true,
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld/%2$lld"
          }
        }
      }
    },
    "%lld%@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "%1$lld%2$@"
          }
        }
      }
    },
    "+%lld": {
      "comment": "A label displaying the number of coins earned by unlocking a particular achievement. The argument is the number of coins.",
      "isCommentAutoGenerated": true
    },
