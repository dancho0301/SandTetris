    "settings_game_area_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust the width of the game area. Changing this value will reset the game"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゲームエリアの横幅を調整できます。値を変更するとゲームがリセットされます"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整游戏区域的宽度。更改此值将重置游戏"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게임 영역의 가로 너비를 조절합니다. 값을 변경하면 게임이 초기화됩니다"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "調整遊戲區域的寬度。更改此值將重置遊戲"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez la largeur de la zone de jeu. Changer cette valeur réinitialisera le jeu"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe die Breite des Spielbereichs an. Durch Aendern dieses Werts wird das Spiel zurueckgesetzt"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta el ancho del área de juego. Cambiar este valor reiniciará el juego"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste a largura da área de jogo. Alterar este valor reiniciará o jogo"
          }
        }
      }
    },
    "settings_game_settings_changed_message": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Game settings have been changed. Do you want to reset the game?\n\nChoose \"Revert\" to restore settings to their previous state."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ゲーム設定が変更されました。ゲームをリセットしますか？\n\n「元に戻す」を選ぶと、設定を変更前の状態に戻します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "游戏设置已更改。是否要重置游戏？\n\n选择「还原」可恢复到之前的设置。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "게임 설정이 변경되었습니다. 게임을 초기화하시겠습니까?\n\n「되돌리기」를 선택하면 설정을 이전 상태로 되돌립니다."
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "遊戲設定已更改。是否要重置遊戲？\n\n選擇「還原」可恢復到之前的設定。"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les paramètres du jeu ont été modifiés. Voulez-vous réinitialiser le jeu ?\n\nChoisissez Annuler pour restaurer les paramètres précédents."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die Spieleinstellungen wurden geaendert. Moechtest du das Spiel zuruecksetzen?\n\nWaehle Zuruecksetzen, um die vorherigen Einstellungen wiederherzustellen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La configuración del juego ha cambiado. ¿Deseas reiniciar el juego?\n\nElige Revertir para restaurar la configuración anterior."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As configurações do jogo foram alteradas. Deseja reiniciar o jogo?\n\nEscolha Reverter para restaurar as configurações anteriores."
          }
        }
      }
    },
