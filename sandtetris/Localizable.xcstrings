    "settings_sensitivity_description": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Adjust horizontal movement responsiveness. Higher values make blocks move faster in response to finger movement"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "横移動の反応速度を調整できます。値が大きいほど、指の動きに対してブロックが速く移動します"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "调整水平移动响应速度。数值越大，方块对手指移动的响应越快"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "수평 이동 반응 속도를 조절합니다. 값이 클수록 손가락 움직임에 블록이 빠르게 반응합니다"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "調整水平移動響應速度。數值越大，方塊對手指移動的響應越快"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajustez la réactivité des mouvements horizontaux. Des valeurs plus élevées font bouger les blocs plus rapidement"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Passe die horizontale Bewegungsempfindlichkeit an. Hoehere Werte lassen Bloecke schneller auf Fingerbewegungen reagieren"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajusta la sensibilidad al movimiento horizontal. Valores más altos hacen que los bloques respondan más rápido"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajuste a sensibilidade ao movimento horizontal. Valores mais altos fazem os blocos responderem mais rapidamente"
          }
        }
      }
    },
